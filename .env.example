# Copier en « .env » puis renseigner. (.env est ignoré par git.)

# URL de l'Ollama de la racine, vu depuis les conteneurs Open WebUI/Docling.
# host.docker.internal pointe vers l'hôte (où tourne Ollama sur 11434).
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Clé d'API générée dans Open WebUI :
#   Open WebUI (http://localhost:3001) → Paramètres → Compte → Clés API → Créer.
OPENWEBUI_API_KEY=

# Modèle interrogé par le RAG (doit exister dans Ollama / Open WebUI).
# qwen2.5:7b-rag : variante de qwen2.5:7b (Q4_K_M, ~5 Go) avec num_gpu=99 et
# num_ctx=8192 figés (créée par install-ollama.sh). Tient ENTIÈREMENT sur la
# RTX 3080 (~111 tok/s, GPU à 90 %+). Le 14b (~9 Go) débordait sur CPU faute de
# VRAM (~7 tok/s). Voir « Exploiter le maximum du GPU » dans le README.
RAG_MODEL=qwen2.5:7b-rag

# Modèle multimodal pour décrire le CONTENU des images à l'import
# (import-corpus.py / image_extract.py). Doit exister dans Ollama.
VISION_MODEL=llava:7b

# OCR GPU des PDF scannés (docling_ocr.py). Concurrence des OCR Docling :
# 1 = strictement sérialisé (le plus fiable, évite les timeouts 504), 2 = un peu
# plus rapide si le GPU encaisse. Timeout par fichier en secondes.
DOCLING_OCR_CONCURRENCY=1
DOCLING_OCR_TIMEOUT=900

# Id de la collection « Connaissances ». RECOMMANDÉ de le renseigner : les scripts
# (import-corpus.py, corriger.py) ciblent la base par cet id, donc un renommage de
# la collection par un admin ne casse rien (l'id ne change pas).
#   Open WebUI → Espace de travail → Connaissances → (ouvrir la base) → id dans l'URL,
#   ou : ./gerer-collections.py --liste
#   Laisser vide pour cibler la base par son nom à la place.
RAG_COLLECTION_ID=
